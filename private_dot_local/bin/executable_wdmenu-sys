#!/bin/sh

shutdown_icon="’Ćæ"
reboot_icon="¾░£ē"
kill_icon="¾░Üī"

choice="$(
    printf "%s shutdown\n%s reboot\n%s kill\n" \
        "$shutdown_icon" "$reboot_icon" "$kill_icon" |
    dmenu -i -c -l 3 -p "Power Menu"
)"

confirm() {
    printf "no\nyes\n" | dmenu -i -c -l 2 -p "Are you sure?"
}

case "$choice" in
    "$shutdown_icon shutdown")
        [ "$(confirm)" = "yes" ] && sudo shutdown now
        ;;
    "$reboot_icon reboot")
        [ "$(confirm)" = "yes" ] && sudo reboot
        ;;
    "$kill_icon kill")
        ps -u "$USER" -o pid,comm,%cpu,%mem |
            dmenu -i -c -l 10 -p "Kill:" |
            awk '{print $1}' |
            xargs -r kill
        ;;
    *)
        exit 1
        ;;
esac
